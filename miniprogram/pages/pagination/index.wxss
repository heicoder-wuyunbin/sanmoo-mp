.header {
  margin-bottom: 20rpx;
}

.subtitle {
  margin-top: 8rpx;
  color: var(--auxiliary-color);
  font-size: 26rpx;
}

.archive-page {
  padding-bottom: 80rpx;
}

.year-nav {
  display: flex;
  padding: 12rpx 0 18rpx;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.year-item {
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
  color: var(--text-color);
  border-radius: var(--radius-pill);
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.year-item.active {
  color: #ffffff;
  background-color: var(--primary-color);
  font-weight: 600;
}

.month-section {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #f9fafb;
  border-bottom: 1rpx solid var(--divider-light-color);
}

.month-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--title-color);
}

.month-count {
  font-size: 24rpx;
  color: var(--auxiliary-color);
}

.month-toggle {
  font-size: 20rpx;
  color: var(--auxiliary-color);
}

.article-list {
  padding: 12rpx 0;
}

.article-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.article-item:last-child {
  border-bottom: none;
}

.article-title {
  color: var(--title-color);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.article-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.article-label {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-soft-color);
  color: var(--primary-color);
  font-size: 22rpx;
  font-weight: 600;
}

.article-day {
  font-size: 22rpx;
  color: var(--auxiliary-color);
}

.article-meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  font-size: 22rpx;
  color: var(--auxiliary-color);
}

.meta-pill {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: #f7f8fa;
}

.article-cta {
  margin-top: 12rpx;
  width: fit-content;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-soft-color);
  color: var(--primary-color);
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
}

.loading {
  text-align: center;
  color: var(--auxiliary-color);
  padding: 20rpx 0;
}

.night-mode .year-item {
  color: #d1d5db;
  background: rgba(255,255,255,0.06);
}

.night-mode .year-item.active {
  background: #2563eb;
}

.night-mode .subtitle,
.night-mode .month-count,
.night-mode .month-toggle,
.night-mode .article-day,
.night-mode .article-meta,
.night-mode .loading {
  color: #9ca3af;
}

.night-mode .month-title,
.night-mode .article-title {
  color: #f3f4f6;
}

.night-mode .article-label,
.night-mode .article-cta {
  background: rgba(96, 165, 250, 0.14);
  color: #93c5fd;
}

.night-mode .meta-pill {
  background: rgba(255,255,255,0.06);
}
