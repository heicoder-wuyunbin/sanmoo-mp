<view class="container favorites-page {{ nightMode ? 'night-mode' : '' }}" bindtap="closeSwipe">
  <!-- ============ 顶部 Hero 区 ============ -->
  <view class="page-hero">
    <view class="hero-brand">
      <image class="icon-svg icon-svg--white" src="../../assets/favorite.svg" mode="aspectFit"></image>
    </view>
    <text class="hero-title">我的书签</text>
    <text class="hero-subtitle">保存高价值文章，方便后续回看与持续阅读</text>
  </view>

  <!-- ============ 内容区 ============ -->
  <view class="content-wrap">
    <!-- 空状态 -->
    <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">
      <image class="empty-icon icon-svg icon-svg--xl" src="../../assets/favorite.svg" mode="aspectFit"></image>
      <text class="empty-title">暂无书签</text>
      <text class="empty-desc">你还没有保存任何文章，去发现值得保存的内容吧</text>
    </view>

    <!-- 文章列表 - 滑动删除 -->
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="swipe-item {{openedId === item.id ? 'opened' : ''}}"
    >
      <view class="swipe-actions">
        <view
          class="delete-action"
          data-id="{{item.id}}"
          catchtap="removeFavorite"
        >
          <text>{{actionLoadingId === item.id ? '处理中…' : '移除书签'}}</text>
        </view>
      </view>

      <view
        class="swipe-content {{openedId === item.id ? 'opened' : ''}}"
        data-id="{{item.id}}"
        bindtap="goToArticleDetail"
        bindtouchstart="onItemTouchStart"
        bindtouchend="onItemTouchEnd"
      >
        <view class="article-card">
          <view class="article-meta-row">
            <text class="article-category-tag">{{item.categoryName || 'TECH'}}</text>
            <text class="article-date">{{item.createTime ? item.createTime.slice(0, 10) : ''}}</text>
          </view>
          <text class="article-title">{{item.title}}</text>
          <text class="article-excerpt">{{item.description || '点击继续阅读全文，稍后可再次添加书签。'}}</text>
          <view class="article-footer-row">
            <view class="footer-meta">
              <text class="meta-read">阅读 {{item.readNum || 0}}</text>
            </view>
            <text class="cta-arrow">→</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-text">加载中…</text>
    </view>
  </view>

  <view class="back-top {{ showBackTop ? 'show' : '' }}" bindtap="backToTop">↑</view>
</view>
