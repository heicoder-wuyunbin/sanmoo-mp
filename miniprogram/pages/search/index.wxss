/* ============================================================
   搜索页样式 - 技术博客极简风格
   ============================================================ */

.search-page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

/* ============ Hero 头部区 ============ */
.page-hero {
  background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 55%, #0c4a6e 100%);
  padding: 48rpx 40rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-brand {
  display: inline-flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.brand-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: #7dd3fc;
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: -1rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #f8fafc;
  line-height: 1.2;
  letter-spacing: -0.3rpx;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(148, 163, 184, 0.9);
  line-height: 1.5;
}

.hero-cut {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1rpx;
  height: 40rpx;
  background: linear-gradient(to bottom right, transparent 49.5%, #f8fafc 50%);
}

/* ============ 悬浮搜索框 ============ */
.search-float-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: -32rpx 32rpx 24rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
  position: relative;
  z-index: 10;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 12rpx;
}



.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #0f172a;
  line-height: 1.4;
}

.search-placeholder {
  color: #94a3b8;
  font-size: 28rpx;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e2e8f0;
  border-radius: 50%;
  flex-shrink: 0;
}

.clear-icon {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1;
}

.search-btn {
  height: 72rpx;
  padding: 0 28rpx;
  background: #0f172a;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ============ 搜索结果区 ============ */
.results-section {
  padding: 8rpx 32rpx 32rpx;
}

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.results-label {
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 3rpx;
  font-weight: 600;
}

.results-count {
  font-size: 22rpx;
  color: #64748b;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-weight: 500;
}

/* 结果卡片 */
.result-card {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  transition: all 0.15s ease;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.result-card:active {
  transform: scale(0.99);
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.08);
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.result-category {
  font-size: 22rpx;
  font-weight: 600;
  color: #0ea5e9;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  padding: 6rpx 14rpx;
  background: #e0f2fe;
  border-radius: 8rpx;
}

.result-date {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: 0.5rpx;
}

.result-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.3rpx;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-excerpt {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  color: #64748b;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-read {
  font-size: 24rpx;
  font-weight: 500;
  color: #475569;
}

.result-cta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #0ea5e9;
}

.cta-arrow {
  font-size: 22rpx;
}

/* 加载状态 */
.loading-state {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0ea5e9;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  margin: 16rpx 0;
}

.empty-big-num {
  font-size: 140rpx;
  font-weight: 700;
  color: #e2e8f0;
  font-family: 'SF Mono', 'Menlo', monospace;
  line-height: 1;
  letter-spacing: -2rpx;
  margin-bottom: 8rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #334155;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.5;
}

/* ============ 搜索建议区 ============ */
.suggestions-section {
  padding: 8rpx 32rpx 32rpx;
}

.suggest-block {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.suggest-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.suggest-head-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.suggest-mark {
  width: 6rpx;
  height: 32rpx;
  background: #0f172a;
  border-radius: 4rpx;
}

.suggest-mark--alt {
  background: #0ea5e9;
}

.suggest-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.3rpx;
}

.suggest-clear {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.pill-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.keyword-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: #f1f5f9;
  border-radius: 100rpx;
  transition: all 0.15s ease;
  min-width: 0;
  justify-content: flex-start;
}

.keyword-pill:active {
  background: #e2e8f0;
  transform: scale(0.97);
}

.keyword-pill--hot {
  background: #fef3c7;
}

.keyword-pill--hot .pill-text {
  color: #92400e;
}

.pill-rank {
  font-size: 20rpx;
  font-weight: 700;
  color: #d97706;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.pill-text {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 热搜前3特殊样式 */
.keyword-pill--top1 {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border: 1rpx solid #fbbf24;
}

.keyword-pill--top1 .pill-text {
  color: #92400e;
  font-weight: 600;
}

.keyword-pill--top1 .pill-rank {
  color: #ffffff;
  background: #ef4444;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.keyword-pill--top2 {
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
  border: 1rpx solid #cbd5e1;
}

.keyword-pill--top2 .pill-text {
  color: #334155;
  font-weight: 600;
}

.keyword-pill--top2 .pill-rank {
  color: #ffffff;
  background: #f97316;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.keyword-pill--top3 {
  background: linear-gradient(135deg, #fff7ed 0%, #fed7aa 100%);
  border: 1rpx solid #fdba74;
}

.keyword-pill--top3 .pill-text {
  color: #7c2d12;
  font-weight: 600;
}

.keyword-pill--top3 .pill-rank {
  color: #ffffff;
  background: #eab308;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* 回到顶部按钮 */
.back-top-btn {
  position: fixed;
  right: 36rpx;
  bottom: 200rpx;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(145deg, #0ea5e9 0%, #0284c7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(14, 165, 233, 0.35), 0 2rpx 8rpx rgba(2, 132, 199, 0.2);
  z-index: 100;
  opacity: 0;
  transform: translateY(24rpx) scale(0.75);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  pointer-events: none;
}

.back-top-btn.show {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

.back-top-btn::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(ellipse at 35% 25%, rgba(255, 255, 255, 0.25) 0%, transparent 60%);
  pointer-events: none;
}

.back-top-btn:active {
  transform: scale(0.92);
}

.back-top-icon {
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

/* ============ 深色模式适配 ============ */
.search-page.night-mode {
  background: var(--dark-bg-page);
}

.search-page.night-mode .page-hero {
  background: var(--dark-hero-gradient);
}

.search-page.night-mode .hero-cut {
  background: linear-gradient(to bottom right, transparent 49.5%, var(--dark-bg-page) 50%);
}

.search-page.night-mode .search-float-card {
  background: var(--dark-bg-subtle);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.search-page.night-mode .search-input-wrap .icon-svg {
  filter: brightness(0) invert(1);
}

.search-page.night-mode .search-input {
  color: var(--dark-text-primary);
}

.search-page.night-mode .search-placeholder {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .clear-btn {
  background: var(--dark-border-strong);
}

.search-page.night-mode .clear-icon {
  color: var(--dark-text-regular);
}

.search-page.night-mode .search-btn {
  background: #0ea5e9;
}

.search-page.night-mode .search-btn-text {
  color: #ffffff;
}

.search-page.night-mode .results-label {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .results-count {
  color: var(--dark-text-muted);
}

.search-page.night-mode .result-card {
  background: var(--dark-bg-subtle);
  border-color: var(--dark-border-regular);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.search-page.night-mode .result-category {
  background: rgba(14, 165, 233, 0.15);
  color: var(--dark-accent);
}

.search-page.night-mode .result-date {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .result-title {
  color: var(--dark-text-primary);
}

.search-page.night-mode .result-excerpt {
  color: var(--dark-text-muted);
}

.search-page.night-mode .result-foot {
  border-top-color: var(--dark-border-regular);
}

.search-page.night-mode .meta-read {
  color: var(--dark-text-muted);
}

.search-page.night-mode .result-cta {
  color: var(--dark-accent);
}

.search-page.night-mode .empty-state {
  background: var(--dark-bg-subtle);
  border-color: var(--dark-border-regular);
}

.search-page.night-mode .empty-big-num {
  color: var(--dark-bg-elevated);
}

.search-page.night-mode .empty-title {
  color: var(--dark-text-regular);
}

.search-page.night-mode .empty-desc {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .loading-text {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .suggest-block {
  background: var(--dark-bg-subtle);
  border-color: var(--dark-border-regular);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.search-page.night-mode .suggest-title {
  color: var(--dark-text-primary);
}

.search-page.night-mode .suggest-mark {
  background: var(--dark-accent);
}

.search-page.night-mode .suggest-clear {
  color: var(--dark-text-subtle);
}

.search-page.night-mode .keyword-pill {
  background: var(--dark-bg-elevated);
}

.search-page.night-mode .keyword-pill .pill-text {
  color: var(--dark-text-regular);
}

.search-page.night-mode .keyword-pill--hot {
  background: rgba(251, 191, 36, 0.15);
}

.search-page.night-mode .keyword-pill--hot .pill-text {
  color: #fbbf24;
}

.search-page.night-mode .pill-rank {
  color: #f59e0b;
}

.search-page.night-mode .back-top-btn {
  background: linear-gradient(145deg, #0284c7 0%, #0369a1 100%);
  box-shadow: 0 6rpx 24rpx rgba(14, 165, 233, 0.25);
}
