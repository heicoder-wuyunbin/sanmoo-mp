<view class="container about-page {{ nightMode ? 'night-mode' : '' }}">
  <view class="hero hero-gradient">
    <view class="hero-inner">
      <image class="avatar" src="{{ authorInfo.avatar }}"></image>
      <text class="author-name">{{ authorInfo.name }}</text>
      <text class="author-title">{{ authorInfo.title }}</text>
      <text class="author-intro">{{ authorInfo.introduction }}</text>
      <view class="author-identity">专注后端技术 · 热爱分享与记录成长</view>
    </view>
    <view class="hero-cut"></view>
  </view>

  <view class="content-section">
    <view class="section-card">
      <view class="section-head">
        <view class="section-mark section-mark--alt"></view>
        <view class="section-texts">
          <text class="section-name">关于博客</text>
          <text class="section-caption">About Blog</text>
        </view>
      </view>
      <view class="blog-description">
        <text class="blog-name">{{ blogInfo.name }}</text>
        <text class="blog-desc">{{ blogInfo.description }}</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-mark"></view>
        <view class="section-texts">
          <text class="section-name">联系方式</text>
          <text class="section-caption">Contact</text>
        </view>
      </view>
      <view class="section-desc">支持复制微信号与常用站点链接，便于进一步交流。</view>
      <view class="contact-list">
        <view class="contact-item" bindtap="copyWechat">
          <view class="contact-icon-wrap">
            <image class="icon-svg" src="../../assets/account.svg" mode="aspectFit"></image>
          </view>
          <view class="contact-copy">
            <text class="contact-text">微信</text>
            <text class="contact-desc">复制微信号，进一步沟通技术问题</text>
          </view>
          <text class="contact-arrow">→</text>
        </view>
        <view class="contact-item" bindtap="goToGithub">
          <view class="contact-icon-wrap">
            <image class="icon-svg" src="../../assets/code.svg" mode="aspectFit"></image>
          </view>
          <view class="contact-copy">
            <text class="contact-text">GitHub</text>
            <text class="contact-desc">复制仓库主页链接，查看开源项目</text>
          </view>
          <text class="contact-arrow">→</text>
        </view>
        <view class="contact-item" bindtap="goToCSDN">
          <view class="contact-icon-wrap">
            <image class="icon-svg" src="../../assets/information.svg" mode="aspectFit"></image>
          </view>
          <view class="contact-copy">
            <text class="contact-text">博客主页</text>
            <text class="contact-desc">复制网站地址，持续关注最新文章</text>
          </view>
          <text class="contact-arrow">→</text>
        </view>
      </view>
    </view>

    <!-- 备案信息展示 -->
    <view class="section-card" wx:if="{{filingInfo && filingInfo.icpCode}}">
      <view class="section-head">
        <view class="section-mark section-mark--primary"></view>
        <view class="section-texts">
          <text class="section-name">备案信息</text>
          <text class="section-caption">Filing Information</text>
        </view>
      </view>
      <view class="filing-info">
        <navigator url="{{filingInfo.filingUrl || 'https://beian.miit.gov.cn/'}}" open-type="open-safety-app" class="filing-item">
          <text class="filing-label">ICP 备案号：</text>
          <text class="filing-value">{{filingInfo.icpCode}}</text>
        </navigator>
        <view class="filing-item" wx:if="{{filingInfo.recordType}}">
          <text class="filing-label">备案类型：</text>
          <text class="filing-value">{{filingInfo.recordType}}</text>
        </view>
      </view>
    </view>

    <view class="declaration">
      <text>© 2023-2026 Sanmoo Blog. All rights reserved.</text>
      <text class="declaration-desc">以简约、自然、确定的方式沉淀长期技术价值。</text>
    </view>
  </view>
</view>
