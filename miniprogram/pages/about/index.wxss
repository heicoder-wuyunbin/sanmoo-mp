/* ============================================================
   关于博主页面样式 - 极简技术博客风格
   ============================================================ */

.about-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ============ Hero 区 ============ */
.hero {
  position: relative;
  padding: 40rpx 40rpx 100rpx;
  color: #f8fafc;
  margin-bottom: -40rpx;
  margin-top: -20rpx;
}

.hero-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.author-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}

.author-title {
  font-size: 28rpx;
  color: rgba(203, 213, 225, 0.9);
  margin-bottom: 20rpx;
}

.author-intro {
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(203, 213, 225, 0.85);
  text-align: center;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.author-identity {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #e2e8f0;
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.hero-cut {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1rpx;
  height: 40rpx;
  background: linear-gradient(to bottom right, transparent 49.5%, var(--bg-page) 50%);
}

/* ============ 内容区 ============ */
.content-section {
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  z-index: 3;
}

/* Section 卡片 */
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* Section 头部 */
.section-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-mark {
  width: 6rpx;
  height: 36rpx;
  background: #0f172a;
  border-radius: 4rpx;
}

.section-mark--alt {
  background: #0ea5e9;
}

.section-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
}

.section-caption {
  font-size: 20rpx;
  color: var(--text-subtle);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.section-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--auxiliary-color);
  margin-bottom: 24rpx;
}

/* 博客描述 */
.blog-description {
  padding: 16rpx 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.blog-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.blog-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-subtle);
}

/* 联系方式 */
.contact-list {
  margin-top: 8rpx;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  background: rgba(14, 165, 233, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-copy {
  flex: 1;
}

.contact-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  display: block;
}

.contact-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-muted);
  display: block;
}

.contact-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 10rpx;
}

/* 声明 */
.declaration {
  text-align: center;
  padding: 48rpx 0;
  font-size: 22rpx;
  color: var(--text-muted);
}

.declaration text {
  display: block;
}

.declaration-desc {
  margin-top: 8rpx;
}

/* ============ 深色模式适配 ============ */
.about-page.night-mode {
  background-color: #111827;
}

.about-page.night-mode .section-card {
  background-color: #1f2937;
  border-color: #374151;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.about-page.night-mode .author-name {
  color: #f1f5f9;
}

.about-page.night-mode .author-title,
.about-page.night-mode .author-intro {
  color: #cbd5e1;
}

.about-page.night-mode .author-identity {
  background: rgba(96, 165, 250, 0.14);
  border-color: rgba(56, 189, 248, 0.2);
  color: #93c5fd;
}

.about-page.night-mode .section-name {
  color: #f1f5f9;
}

.about-page.night-mode .section-mark {
  background: #7dd3fc;
}

.about-page.night-mode .section-desc {
  color: #94a3b8;
}

.about-page.night-mode .blog-description {
  background: rgba(255, 255, 255, 0.04);
}

.about-page.night-mode .blog-name {
  color: #f1f5f9;
}

.about-page.night-mode .blog-desc {
  color: #94a3b8;
}

.about-page.night-mode .contact-item {
  border-bottom-color: #374151;
}

.about-page.night-mode .contact-text {
  color: #f1f5f9;
}

.about-page.night-mode .contact-desc,
.about-page.night-mode .contact-arrow {
  color: #64748b;
}

.about-page.night-mode .contact-icon-wrap {
  background: rgba(96, 165, 250, 0.14);
}

.about-page.night-mode .declaration {
  color: #64748b;
}