/* ============================================================
   专题列表页样式 - 技术博客专业风格
   ============================================================ */

.container {
  min-height: 100vh;
  padding: 0;
  background: #f8fafc;
}

/* ============ Hero 区 ============ */
.topic-hero {
  background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 55%, #0c4a6e 100%);
  color: #f1f5f9;
  padding: 56rpx 40rpx 64rpx;
  position: relative;
  overflow: hidden;
}

.topic-hero::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
  border-radius: 50%;
}

.topic-hero::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 250rpx;
  height: 250rpx;
  background: radial-gradient(circle, rgba(125, 211, 252, 0.08) 0%, transparent 60%);
  border-radius: 50%;
}

.topic-hero-inner {
  position: relative;
  z-index: 2;
}

.topic-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 100rpx;
  background: rgba(14, 165, 233, 0.18);
  border: 1rpx solid rgba(125, 211, 252, 0.3);
  color: #7dd3fc;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.topic-hero-badge::before {
  content: '{';
  font-size: 20rpx;
  opacity: 0.6;
}

.topic-hero-badge::after {
  content: '}';
  font-size: 20rpx;
  opacity: 0.6;
}

.topic-hero-title {
  margin-top: 28rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}

.topic-hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(203, 213, 225, 0.85);
}

/* ============ 内容区 ============ */
.content-section {
  padding: 40rpx 32rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 3;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-head-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-mark {
  width: 6rpx;
  height: 36rpx;
  background: #0ea5e9;
  border-radius: 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.3rpx;
}

.section-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

/* ============ 专题列表 ============ */
.topic-list {
  margin-top: 16rpx;
}

.topic-card {
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  transition: all 0.15s ease;
}

.topic-card:active {
  transform: scale(0.99);
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
}

.topic-card--featured {
  border-color: rgba(14, 165, 233, 0.25);
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.12);
}

.topic-cover {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0c4a6e 100%);
  position: relative;
  overflow: hidden;
}

.topic-cover--featured {
  height: 240rpx;
}

.topic-cover image {
  width: 100%;
  height: 100%;
  display: block;
}

.topic-cover-fallback {
  width: 100%;
  height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
  position: relative;
}

.topic-cover-fallback::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.25) 0%, transparent 60%);
  border-radius: 50%;
}

.topic-cover-fallback-title {
  position: relative;
  z-index: 2;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #ffffff;
}

.topic-info {
  padding: 28rpx;
}

.topic-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.topic-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  padding: 0 24rpx;
  border-radius: 100rpx;
  background: rgba(14, 165, 233, 0.1);
  color: #0ea5e9;
  font-size: 24rpx;
  font-weight: 600;
}

.topic-time {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.topic-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #64748b;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.topic-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.topic-count {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 100rpx;
  background: #f1f5f9;
  font-size: 24rpx;
  color: #64748b;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.topic-enter {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0ea5e9;
}

.topic-enter::after {
  content: '→';
  font-size: 24rpx;
}

/* ============ 加载状态 ============ */
.loading {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

/* ============ 空状态 ============ */
.empty {
  padding: 80rpx 20rpx;
  text-align: center;
}

.empty-image {
  display: block;
  margin-bottom: 20rpx;
  font-size: 100rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
  color: #cbd5e1;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
}

/* ============ 深色模式 ============ */
.container.night-mode {
  background: #020617;
}

.container.night-mode .topic-hero {
  background: linear-gradient(160deg, #020617 0%, #0f172a 45%, #1e293b 70%, #0f172a 100%);
}

.container.night-mode .topic-hero::before {
  background: radial-gradient(circle, rgba(14, 165, 233, 0.15) 0%, transparent 60%);
}

.container.night-mode .topic-hero::after {
  background: radial-gradient(circle, rgba(125, 211, 252, 0.06) 0%, transparent 60%);
}

.container.night-mode .topic-hero-badge {
  background: rgba(14, 165, 233, 0.18);
  border-color: rgba(125, 211, 252, 0.25);
  color: var(--dark-accent);
}

.container.night-mode .topic-hero-title {
  color: var(--dark-text-primary);
}

.container.night-mode .topic-hero-desc {
  color: rgba(148, 163, 184, 0.9);
}

.container.night-mode .section-title {
  color: var(--dark-text-primary);
}

.container.night-mode .section-desc {
  color: var(--dark-text-subtle);
}

.container.night-mode .section-mark {
  background: linear-gradient(180deg, #0ea5e9 0%, #38bdf8 100%);
}

.container.night-mode .topic-card {
  background: var(--dark-bg-subtle);
  border-color: rgba(30, 41, 59, 0.8);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
}

.container.night-mode .topic-card:active {
  background: var(--dark-bg-elevated);
}

.container.night-mode .topic-card--featured {
  border-color: rgba(14, 165, 233, 0.4);
  box-shadow: 0 8rpx 28rpx rgba(14, 165, 233, 0.15),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.container.night-mode .topic-cover {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%);
}

.container.night-mode .topic-cover-fallback::before {
  background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
}

.container.night-mode .topic-cover-fallback-title {
  color: var(--dark-text-primary);
}

.container.night-mode .topic-badge {
  background: rgba(14, 165, 233, 0.15);
  color: var(--dark-accent);
  border: 1rpx solid rgba(14, 165, 233, 0.25);
}

.container.night-mode .topic-desc {
  color: var(--dark-text-muted);
}

.container.night-mode .topic-count {
  background: rgba(30, 41, 59, 0.6);
  color: var(--dark-text-muted);
}

.container.night-mode .topic-time {
  color: var(--dark-text-subtle);
}

.container.night-mode .topic-enter {
  color: #0ea5e9;
}

.container.night-mode .topic-footer {
  border-top-color: rgba(30, 41, 59, 0.6);
}

.container.night-mode .empty-title {
  color: var(--dark-text-primary);
}

.container.night-mode .empty-desc {
  color: var(--dark-text-subtle);
}

.container.night-mode .empty-image {
  color: var(--dark-bg-elevated);
}

.container.night-mode .loading {
  color: var(--dark-text-subtle);
}