/* ============================================================
   首页样式 - 极简技术博客风格
   ============================================================ */

.home-page {
  padding-bottom: 120rpx;
}

/* ============ Hero 区 ============ */
.hero {
  position: relative;
  padding: 20rpx 40rpx 80rpx;
  color: #f8fafc;
  margin-bottom: -40rpx;
  margin-top: -20rpx;
}

.hero-inner {
  position: relative;
  z-index: 2;
}

/* 顶栏 */
.hero-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(14, 165, 233, 0.25);
  border: 1rpx solid rgba(125, 211, 252, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.logo-text {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 28rpx;
  font-weight: 700;
  color: #7dd3fc;
  letter-spacing: -1rpx;
}

.hero-brand-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
  letter-spacing: 0.3rpx;
}

.brand-tag {
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(148, 163, 184, 0.8);
  letter-spacing: 4rpx;
}

.hero-actions {
  display: flex;
  gap: 12rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.hero-actions .icon-svg {
  opacity: 0.85;
}

/* Hero 主内容 */
.hero-content {
  padding: 8rpx 0 24rpx;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 20rpx;
  background: rgba(14, 165, 233, 0.15);
  border: 1rpx solid rgba(14, 165, 233, 0.3);
  border-radius: 100rpx;
  margin-bottom: 28rpx;
}

.eyebrow-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #38bdf8;
  box-shadow: 0 0 12rpx rgba(56, 189, 248, 0.6);
}

.eyebrow-text {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  color: #7dd3fc;
}

.hero-title {
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
  margin-bottom: 20rpx;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(203, 213, 225, 0.85);
  margin-bottom: 36rpx;
}

/* 统计数据 */
.hero-stats {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin-bottom: 28rpx;
  backdrop-filter: blur(10rpx);
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #f1f5f9;
  letter-spacing: -0.5rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.8);
  letter-spacing: 2rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.12);
}

/* 入口按钮 */
.hero-entry-row {
  display: flex;
  gap: 16rpx;
}

.hero-entry {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #e2e8f0;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  transition: all 0.15s ease;
}

.hero-entry--primary {
  background: #ffffff;
  color: #0f172a;
  font-weight: 600;
  border: none;
}

.entry-arrow {
  font-weight: 600;
}

/* Hero 底部切角装饰 */
.hero-cut {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1rpx;
  height: 40rpx;
  background: linear-gradient(to bottom right, transparent 49.5%, var(--bg-page) 50%);
}

/* ============ 内容区 ============ */
.content-section {
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  z-index: 3;
}

/* Section 头部 */
.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-head-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-mark {
  width: 6rpx;
  height: 36rpx;
  background: #0f172a;
  border-radius: 4rpx;
}

.section-mark--alt {
  background: #0ea5e9;
}

.section-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
}

.section-caption {
  font-size: 20rpx;
  color: var(--text-subtle);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.more-arrow {
  font-size: 22rpx;
}

/* ============ 文章卡片 ============ */
.article-item {
  position: relative;
  margin-bottom: 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.article-item.is-opened .article-card {
  transform: translateX(-140rpx);
}

.article-item.is-opened .swipe-actions {
  opacity: 1;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  opacity: 0;
  transition: opacity 0.2s ease;
  z-index: 1;
}

.swipe-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.article-card {
  position: relative;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 32rpx;
  z-index: 2;
  transition: transform 0.2s ease, box-shadow 0.15s ease;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.article-card:active {
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
  transform: translateX(0) scale(0.99);
}

/* Editor's Pick 丝带 */
.article-ribbon {
  position: absolute;
  top: 0;
  right: 32rpx;
  padding: 10rpx 20rpx 8rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border-radius: 0 0 10rpx 10rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 文章头部 */
.article-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.article-category {
  font-size: 22rpx;
  color: #0ea5e9;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  padding: 6rpx 14rpx;
  background: #e0f2fe;
  border-radius: 8rpx;
}

.article-date {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 文章标题 */
.article-title {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.5rpx;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 文章摘要 */
.article-excerpt {
  font-size: 28rpx;
  line-height: 1.7;
  color: #64748b;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 标签 */
.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-chip {
  font-size: 22rpx;
  color: #0ea5e9;
  background: rgba(14, 165, 233, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 500;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 底部信息 */
.article-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}

.foot-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.meta-read {
  font-weight: 500;
  color: #64748b;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.meta-dot {
  color: #cbd5e1;
}

.meta-estimate {
  font-family: 'SF Mono', 'Menlo', monospace;
  color: #94a3b8;
}

.foot-cta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0ea5e9;
}

.cta-arrow {
  font-size: 24rpx;
  transition: transform 0.15s ease;
}

.article-card:active .cta-arrow {
  transform: translateX(6rpx);
}

/* ============ 专题卡片 ============ */
.topics-block {
  margin-top: 56rpx;
}

.topics-scroll {
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.topics-track {
  display: flex;
  gap: 20rpx;
  padding-right: 32rpx;
}

.topic-card {
  flex-shrink: 0;
  width: 280rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-regular);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.15s ease;
}

.topic-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-card);
}

.topic-cover {
  height: 160rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0c4a6e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.topic-cover::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.3) 0%, transparent 60%);
  border-radius: 50%;
}

.topic-bracket {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 40rpx;
  color: #38bdf8;
  font-weight: 300;
  opacity: 0.6;
}

.topic-index {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin: 0 8rpx;
}

.topic-body {
  padding: 20rpx;
}

.topic-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.topic-meta {
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* ============ 返回顶部按钮 ============ */
.back-top {
  position: fixed;
  right: 36rpx;
  bottom: 200rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #0ea5e9 0%, #0284c7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(14, 165, 233, 0.35), 0 2rpx 8rpx rgba(2, 132, 199, 0.2);
  z-index: 500;
  opacity: 0;
  transform: translateY(24rpx) scale(0.75);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 600;
  overflow: hidden;
}

.back-top::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(ellipse at 35% 25%, rgba(255, 255, 255, 0.25) 0%, transparent 60%);
  pointer-events: none;
}

.back-top.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.back-top:active {
  transform: scale(0.92);
}

/* ============ 深色模式适配 ============ */
.home-page.night-mode .section-name {
  color: #f1f5f9;
}

.home-page.night-mode .section-mark {
  background: #7dd3fc;
}

.home-page.night-mode .article-card {
  background: #111827;
  border-color: #1f2937;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.home-page.night-mode .article-title {
  color: #f1f5f9;
}

.home-page.night-mode .article-excerpt {
  color: #cbd5e1;
}

.home-page.night-mode .article-category {
  color: #7dd3fc;
}

.home-page.night-mode .article-date,
.home-page.night-mode .meta-estimate {
  color: #64748b;
}

.home-page.night-mode .meta-read {
  color: #cbd5e1;
}

.home-page.night-mode .meta-dot {
  color: #374151;
}

.home-page.night-mode .tag-chip {
  background: rgba(56, 189, 248, 0.15);
  color: #7dd3fc;
}

.home-page.night-mode .foot-cta {
  color: #38bdf8;
}

.home-page.night-mode .article-foot {
  border-top-color: #1f2937;
}

.home-page.night-mode .topic-card {
  background: #111827;
  border-color: #1f2937;
}

.home-page.night-mode .topic-title {
  color: #f1f5f9;
}

.home-page.night-mode .topic-meta {
  color: #64748b;
}

.home-page.night-mode .back-top {
  background: linear-gradient(145deg, #0284c7 0%, #0369a1 100%);
  box-shadow: 0 6rpx 24rpx rgba(14, 165, 233, 0.25);
}
