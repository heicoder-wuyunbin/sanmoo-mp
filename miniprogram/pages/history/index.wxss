/* ============================================================
   浏览历史页样式 - 技术博客极简风格
   ============================================================ */

.history-page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

/* ============ 顶部 Hero 区 ============ */
.page-hero {
  background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 55%, #0c4a6e 100%);
  padding: 48rpx 40rpx 56rpx;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-brand {
  display: inline-flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.brand-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: #7dd3fc;
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: -1rpx;
}

.hero-content {
  padding-right: 120rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #f8fafc;
  line-height: 1.2;
  letter-spacing: -0.3rpx;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(148, 163, 184, 0.9);
  line-height: 1.5;
}

/* 清空按钮 - Hero 右上角 */
.clear-btn {
  position: absolute;
  top: 44rpx;
  right: 40rpx;
  padding: 12rpx 22rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.clear-text {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(248, 250, 252, 0.85);
  letter-spacing: 0.5rpx;
}

.clear-btn:active {
  background: rgba(255, 255, 255, 0.15);
}

/* ============ 内容区 ============ */
.content-wrap {
  padding: 32rpx 32rpx 8rpx;
}

/* ============ 深色模式 ============ */
.history-page.night-mode {
  background: #0b1120;
}

.history-page.night-mode .page-hero {
  background: linear-gradient(160deg, #020617 0%, #0f172a 55%, #020617 100%);
}

.history-page.night-mode .clear-btn {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.12);
}

.history-page.night-mode .clear-text {
  color: rgba(226, 232, 240, 0.8);
}
