<view class="container categories-page {{ nightMode ? 'night-mode' : '' }}">
  <!-- ============ 顶部 Hero 区 ============ -->
  <view class="page-hero">
    <view class="hero-brand">
      <image class="icon-svg icon-svg--white" src="../../assets/tag.svg" mode="aspectFit"></image>
    </view>
    <text class="hero-title">分类浏览</text>
    <text class="hero-subtitle">按主题进入内容目录</text>
  </view>

  <!-- ============ 分类导航 Tab ============ -->
  <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tabs-track">
      <view
        class="tab-item {{ selectedCategoryId === null || selectedCategoryId === 0 ? 'is-active' : '' }}"
        data-id="0"
        bindtap="selectCategory"
      >
        <text class="tab-text">全部</text>
      </view>
      <view
        wx:for="{{ categories }}"
        wx:key="id"
        class="tab-item {{ selectedCategoryId === item.id ? 'is-active' : '' }}"
        data-id="{{ item.id }}"
        bindtap="selectCategory"
      >
        <text class="tab-text">{{ item.name }}</text>
        <text wx:if="{{ item.articleCount !== undefined }}" class="tab-count">{{ item.articleCount }}</text>
      </view>
    </view>
  </scroll-view>

  <!-- ============ 文章列表组件 ============ -->
  <view class="content-wrap">
    <article-list
      articles="{{articles}}"
      loading="{{loading}}"
      showBackTop="{{showBackTop}}"
      emptyText="暂无文章"
      emptyDesc="该分类下还没有内容"
      bind:articletap="onArticleTap"
      bind:backtop="backToTop"
    />
  </view>
</view>
