/* ============================================================
   article-list 组件样式
   设计风格：极简 · 专业 · 技术感 — 统一 Sky 蓝色系
   ============================================================ */

/* ========== 文章卡片 ========== */
.article-card {
  position: relative;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  transition: box-shadow 0.15s ease, transform 0.15s ease;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.article-card:active {
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
  transform: scale(0.99);
}

/* 文章头部 */
.article-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.article-category {
  font-size: 22rpx;
  color: #0ea5e9;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  padding: 6rpx 14rpx;
  background: #e0f2fe;
  border-radius: 8rpx;
}

.article-date {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 文章标题 */
.article-title {
  display: block;
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.5rpx;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 文章摘要 */
.article-excerpt {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: #64748b;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 标签 */
.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-chip {
  font-size: 22rpx;
  color: #0ea5e9;
  background: rgba(14, 165, 233, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 500;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 底部信息 */
.article-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}

.foot-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.meta-read {
  font-weight: 500;
  color: #64748b;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.meta-dot {
  color: #cbd5e1;
}

.meta-estimate {
  font-family: 'SF Mono', 'Menlo', monospace;
  color: #94a3b8;
}

.foot-cta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0ea5e9;
}

.cta-arrow {
  font-size: 24rpx;
  transition: transform 0.15s ease;
}

.article-card:active .cta-arrow {
  transform: translateX(6rpx);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.4;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.6;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* ============================================================
   回到顶部悬浮按钮 — Sky 蓝色主题
   ============================================================ */
.back-top {
  position: fixed;
  right: 36rpx;
  bottom: 200rpx;
  width: 88rpx;
  height: 88rpx;
  z-index: 500;
  opacity: 0;
  transform: translateY(24rpx) scale(0.75);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.back-top.show {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

.back-top:active {
  transform: scale(0.92);
}

/* 按钮主体 */
.back-top-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(145deg, #0ea5e9 0%, #0284c7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(14, 165, 233, 0.35), 0 2rpx 8rpx rgba(2, 132, 199, 0.2);
  position: relative;
  overflow: hidden;
}

/* 光泽装饰 */
.back-top-inner::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(ellipse at 35% 25%, rgba(255, 255, 255, 0.25) 0%, transparent 60%);
  pointer-events: none;
}

/* 箭头图标 */
.back-top-arrow {
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
  position: relative;
  z-index: 1;
}